{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.sqlite)",
      "Read(**/*.sqlite-*)",
      "Read(data/**)",
      "Read(media/**)",
      "Read(vendor/**)",
      "Read(node_modules/**)",
      "Read(**/*token*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude/changed-files-summary.sh"
          }
        ]
      }
    ]
  }
}
