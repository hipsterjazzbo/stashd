{
  "name": "stashd/stashd",
  "description": "Self-hosted media preservation: Stash → Vault → Broadcasts",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "ext-json": "*",
    "ext-uri": "*",
    "tempest/framework": "^3.0",
    "spiral/roadrunner-http": "^3.6",
    "spiral/roadrunner-cli": "^2.6",
    "nyholm/psr7": "^1.8",
    "symfony/uid": "^7.3",
    "hazel/ytdlphp": "*"
  },
  "repositories": [
    {
      "type": "path",
      "url": "/home/hazel/Projects/ytdlphp",
      "options": {
        "symlink": false
      }
    }
  ],
  "require-dev": {
    "pestphp/pest": "^4.0",
    "laravel/pint": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php ./vendor/bin/tempest install framework -f",
      "@php ./tempest discovery:generate --no-interaction",
      "@php ./tempest key:generate"
    ],
    "post-autoload-dump": [
      "@php ./tempest discovery:generate --no-interaction"
    ],
    "test": "ENVIRONMENT=testing vendor/bin/pest",
    "test:parallel": "ENVIRONMENT=testing vendor/bin/pest --parallel",
    "test:unit": "ENVIRONMENT=testing vendor/bin/pest --testsuite=Unit",
    "test:feature": "ENVIRONMENT=testing vendor/bin/pest --testsuite=Feature",
    "test:feature:parallel": "ENVIRONMENT=testing vendor/bin/pest --testsuite=Feature --parallel",
    "test:docker-smoke": "tests/docker/smoke.sh",
    "test:docker-smoke:no-build": "STASHD_SMOKE_SKIP_BUILD=1 tests/docker/smoke.sh",
    "lint": "vendor/bin/pint --test",
    "format": "vendor/bin/pint"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "pestphp/pest-plugin": true
    }
  }
}
