ENVIRONMENT=local
BASE_URI=http://localhost:8474
STASHD_PUBLIC_URL=http://localhost:8474
STASHD_HTTP_PORT=8474
STASHD_DATA_PATH=data
STASHD_MEDIA_PATH=media
STASHD_LOG_FORMAT=text
STASHD_YTDLP_BINARY=yt-dlp
STASHD_YTDLP_TIMEOUT=600
STASHD_REAL_DOWNLOADS_ENABLED=0
# Optional: supply your own Tempest signing key (see `php tempest key:generate --no-override`).
# If left unset, Stashd generates one automatically on first boot and persists it under STASHD_DATA_PATH.
# SIGNING_KEY=
YOUTUBE_DATA_API_KEY=
PUID=1000
PGID=1000
UMASK=0022
INTERNAL_CACHES=true
DISCOVERY_CACHE=partial
DEBUG_LOG_PATH=null
SERVER_LOG_PATH=null
